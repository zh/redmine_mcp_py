# Local docker-compose configuration.
# Copy to .env and fill in REDMINE_MCP_SECRET; the rest have sensible
# local-dev defaults. .env is git-ignored — never commit it.

# ---------------------------------------------------------------------------
# REQUIRED
# ---------------------------------------------------------------------------

# Signs CSRF cookies. Generate fresh per environment:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
REDMINE_MCP_SECRET=

# ---------------------------------------------------------------------------
# Host binding
# ---------------------------------------------------------------------------

# Host port to map to the container's 7860. Change if 8000 is taken.
HOST_PORT=8000

# ---------------------------------------------------------------------------
# SSRF allowlist (strongly recommended for production)
# ---------------------------------------------------------------------------

# CSV of Redmine hostnames the server is allowed to talk to.
# Example: REDMINE_MCP_ALLOWED_HOSTS=redmine.example.com,redmine.acme.com
# Empty means: any public hostname (private/loopback IPs are still blocked).
REDMINE_MCP_ALLOWED_HOSTS=

# ---------------------------------------------------------------------------
# OAuth redirect allowlist (only for non-loopback web MCP clients)
# ---------------------------------------------------------------------------

# CSV of redirect_uri values for web MCP clients that did not register via
# /oauth/register. Desktop MCP clients use loopback and are auto-allowed
# per RFC 8252 — leave this empty for them.
REDMINE_MCP_ALLOWED_REDIRECTS=

# ---------------------------------------------------------------------------
# Dev-only switches
# ---------------------------------------------------------------------------

# true = permit http:// Redmine URLs, bare-IP hosts, AND don't set the Secure
# flag on the CSRF cookie (required when accessing the server over plain
# http://localhost). NEVER enable in production.
REDMINE_MCP_ALLOW_HTTP=true

# true = honor X-Forwarded-For / X-Real-IP. Enable only when a known reverse
# proxy is in front of this container.
REDMINE_MCP_TRUST_PROXY=false

# ---------------------------------------------------------------------------
# Lifetimes (seconds)
# ---------------------------------------------------------------------------

REDMINE_MCP_TOKEN_TTL_SECONDS=86400
REDMINE_MCP_CODE_TTL_SECONDS=300
REDMINE_MCP_TIMEOUT_SECONDS=30
# DCR client record TTL (Redis only). 30 days.
REDMINE_MCP_CLIENT_TTL_SECONDS=2592000

# ---------------------------------------------------------------------------
# Optional: Redis-backed persistence (survives restarts, multi-instance-ready)
# ---------------------------------------------------------------------------
# Leave both empty to keep the in-memory store. To enable Redis:
#   1. docker compose --profile redis up --build
#   2. Set REDMINE_MCP_REDIS_URL=redis://redis:6379/0
#   3. Generate a Fernet key and set REDMINE_MCP_FERNET_KEY:
#        python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
REDMINE_MCP_REDIS_URL=
REDMINE_MCP_FERNET_KEY=
